# Copy to .env and fill in values — never commit .env

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bluefrost:dev_password@localhost:5432/bluefrost
POSTGRES_PASSWORD=dev_password

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200            # 30 days

# ── OAuth2 social providers ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=                  # PEM string or path to .p8 file

# ── Storage (S3 / Cloudflare R2) ────────────────────────────────────────────
S3_ENDPOINT_URL=                    # leave blank for AWS; set for R2: https://<account>.r2.cloudflarestorage.com
S3_BUCKET_NAME=bluefrost-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto                     # "auto" for R2

# ── Web Push ────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com

# ── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development             # development | production
